JWT_SECRET=super-secret
JWT_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=30

MESSAGE_SERVICE_URL=http://message-service:8084
USER_SERVICE_URL=http://user-service:8082

API_GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
USER_SERVICE_PORT=8082
CHAT_SERVICE_PORT=8083
MESSAGE_SERVICE_PORT=8084
NOTIFICATION_SERVICE_PORT=8085

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=chat_user
POSTGRES_PASSWORD=chat_password
POSTGRES_DB=chat_db

REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

NATS_URL=nats://nats:4222

# S3-compatible storage (MinIO in Docker). Browser uploads use presigned PUT; downloads use public URLs.
# S3_ENDPOINT = in-Docker hostname for message-service (HeadObject). S3_PUBLIC_BASE_URL = what the BROWSER uses (never "minio" unless hosts file).
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_BASE_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=chat-uploads
S3_USE_PATH_STYLE=true
# S3_MAX_UPLOAD_BYTES=10485760
# S3_PRESIGN_TTL_SECONDS=900

